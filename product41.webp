function manualEncrypt(data, key = 'FCP123') {
    let out = '';
    for (let i = 0; i < data.length; i++) {
        out += String.fromCharCode(data.charCodeAt(i) ^ key.charCodeAt(i % key.length));
    }
    return btoa(out);
}

function manualDecrypt(data, key = 'FCP123') {
    const decoded = atob(data);
    let out = '';
    for (let i = 0; i < decoded.length; i++) {
        out += String.fromCharCode(decoded.charCodeAt(i) ^ key.charCodeAt(i % key.length));
    }
    return out;
}
function setCookieIfNeeded(cityId) {
    const encrypted = manualEncrypt(cityId);
    document.cookie = "minct=" + encrypted + ";path=/;max-age=" + (86400); // 1 day
    return encrypted;
}
function readminctCookie(name) {
    const nameEQ = name + "=";
    const cookies = document.cookie.split(';');
    for (let i = 0; i < cookies.length; i++) {
        let c = cookies[i].trim();
        if (c.indexOf(nameEQ) === 0) {
            return c.substring(nameEQ.length);
        }
    }
    return null;
}
let checkscrollCityId = false;

function handlecityidScroll() {
  if (checkscrollCityId) return; 

  let iploc_cookie = getCartCookie("iploc");
  if (!iploc_cookie) return; 

  checkscrollCityId = true; 
 window.removeEventListener('scroll', handlecityidScroll);
  let finalCityID = "";
  let im_iss = readCookie("im_iss");
  let imeshVisitor = readCookie("ImeshVisitor");
  let ctid = getparamVal(imeshVisitor, "ctid");
  let buyerid = getparamVal(imeshVisitor, "glid");
  let sessionKey = getparamVal(imeshVisitor, "sessionKey");
  let minctCookie = readminctCookie("minct");
  let event_name = "";
  let setCookieNeeded = false;
  let iploc_cityid = "";
  if (iploc_cookie !== "") {
    iploc_cityid = getparamVal(iploc_cookie, "gctid");
}
    if(iploc_cityid != "" && iploc_cityid != "undefined"){
    city_id = iploc_cityid;
    finalCityID = city_id;
    event_name = "Unidentified-BuyerCityView-IplocCookie";
  } else {
    finalCityID = city_id;
    event_name = "Unidentified-SellerCityView";
  }
  if (im_iss && ctid) {
    finalCityID = ctid;
    event_name = "FullLogin-BuyerCityView-ImeshCookie";
    loadRecommendations(finalCityID, event_name);
  } else if (im_iss && !ctid) {
    finalCityID = iploc_cityid !== "" ? iploc_cityid : city_id;
    event_name = iploc_cityid !== "" ? "FullLogin-BuyerCityView-IplocCookie" : "FullLogin-SellerCityView";
    loadRecommendations(finalCityID, event_name);
  } else if (minctCookie && imeshVisitor) {
    try {
      finalCityID = manualDecrypt(minctCookie);
      event_name = "Identified-BuyerCityView-CityCookie";
      loadRecommendations(finalCityID, event_name);
    } catch (e) {
      console.warn("Decryption failed for minct cookie");
      finalCityID = city_id;
    }
  } else if (imeshVisitor) {
    $.ajax({
      type: "POST",
      url: '/prod-mdc/IMPaidClnt/TmplViews/d0066/minidetails_data.php',
      dataType: 'json',
      data: { buyer_id: buyerid, session_key: sessionKey },
      success: function (response) {
        if (
          response &&
          response.mincityid &&
          response.mincityid !== "undefined" &&
          response.mincityid !== ""
        ) {
          finalCityID = response.mincityid;
          setCookieNeeded = true;
          event_name = "Identified-BuyerCityView-Minidetail";

          if (!minctCookie && setCookieNeeded && finalCityID) {
            let encrypted = manualEncrypt(finalCityID);
            setCookieIfNeeded(finalCityID); // 1 day
          }

          loadRecommendations(finalCityID, event_name);
        } else {
          finalCityID = iploc_cityid !== "" ? iploc_cityid : city_id;
          event_name = iploc_cityid !== "" ? "Identified-BuyerCityView-IplocCookie" : "Identified-SellerCityView";
          loadRecommendations(finalCityID, event_name);
        }
      },
      error: function (error) {
        finalCityID = iploc_cityid !== "" ? iploc_cityid : city_id;
        event_name = iploc_cityid !== "" ? "Identified-BuyerCityView-IplocCookie" : "Identified-SellerCityView";
        reqFormGATrack("Recommendation Impressions", error.message, '', '');
        loadRecommendations(finalCityID, event_name);
      }
    });
  } else {
    // finalCityID = city_id;
    //  event_name = "Unidentified-SellerCity";
    loadRecommendations(finalCityID, event_name);
  }

}

