// Add Recommended Section through Ajax
function loadRecommendations(cityId, event_name) {
    let mcat0 = '161977';
    let mcat1 = '';
    let mcat2 = '';
    let mcat3 = '';
    let buyer_id = '266792778';
    let pagelinktype = 'category';
    let proserve = 'P';
    let rel_count = 9;
    let pagetype = 'category';
    let rel_modid = 'FCP';
    let blenqpost_js = 'enqBl_desktop.min.js?v=396';
    let pagectas = 'product';
    let video_prd = '';
    let track_event_name = event_name;
    let cars = [];
    let checkscrollrecommend = 0;
$(window).on('scroll.recommend', function() {
    try {
        if (checkscrollrecommend === 0) {
            // Immediately disable the scroll listener to prevent multiple calls
            $(window).off('scroll.recommend');
            checkscrollrecommend = 1;

            $.ajax({
                type: "POST",
                headers: {
                    'Cache-Control': 'no-cache, no-store, must-revalidate',
                    'Pragma': 'no-cache',
                    'Expires': '0'
                },
                url: '/prod-fcp/files/recommended_data.php',
                dataType: 'json',
                data: {
                    usrglid: decryptedglid,
                    mcat0: mcat0,
                    mcat1: mcat1,
                    mcat2: mcat2,
                    mcat3: mcat3,
                    city_id: cityId,
                    buyer_id: buyer_id,
                    rel_count: rel_count,
                    pagetype: pagetype,
                    rel_modid: rel_modid,
                    pagelinktype: pagelinktype,
                    blenqpost_js: blenqpost_js,
                    pagectas: pagectas
                },
                success: function(response) {
                    if (response !== '') {
                        if (response.recommended && response.recommended !== "undefined") {
                            $("#recommend_data").html(response.recommended);
                        }
                        if (response.catrecommend && response.catrecommend !== "undefined") {
                            $("#relatedcat").html(response.catrecommend);
                        }
                        if ((ispnsrecset == 0 && ispnsnodisp == 1) || is_cookie_imesh_p_imes !== "") {
                            open_call_html();
                        }
                         setupRecommendationObserver(event_name);
                    }
                }
            });
        }
    } catch (error) {
        let GaMsg = error.message + error.stack.split('\n')[1];
        reqFormGATrack("footer.php", 'recommended_data', GaMsg, decryptedglid);
    }
});

}
function setupRecommendationObserver(event_name) {
    const target = document.getElementById('recommend_data');

    if (!target) {
        console.warn("recommend_data not found");
        return;
    }
    setTimeout(() => {
        if (!target.innerHTML.trim()) {
            console.warn("recommend_data is empty");
            return;
        }
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                // console.log("Observed entry", entry); // Debug
                if (entry.isIntersecting && entry.intersectionRatio >= 0.4) {
                    reqFormGATrack("Recommendation Impressions", event_name, '', '');
                    observer.unobserve(entry.target);
                }
            });
        }, {
            threshold: [0.4, 0.5, 0.6, 0.7, 0.8]
        });

        observer.observe(target);
    }, 200); // Adjust delay as needed
}




