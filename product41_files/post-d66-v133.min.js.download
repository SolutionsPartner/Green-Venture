    `;$("#rvw_img_pop2").html(popupHTML);let pop_img=document.getElementById("imagebox_sign");const container=document.querySelector(".zoomable");const zoomInBtn=document.getElementById("zoomin");const zoomOutBtn=document.getElementById("zoomout");let isZoomMode=!1;let isZoomed=!1;let zoomLevel=2;const minZoom=1.25;const maxZoom=4;const zoomSpeed=0.1;function updateZoomButtons(){zoomInBtn.disabled=isZoomMode;zoomOutBtn.disabled=!isZoomMode}
function applyZoom(){container.classList.add("zoomable--zoomed");container.style.setProperty("--zoom",zoomLevel);pop_img.style.cursor="zoom-out";isZoomed=!0}
function resetZoom(){container.classList.remove("zoomable--zoomed");container.style.setProperty("--zoom",1);container.style.setProperty("--zoom-pos-x","50%");container.style.setProperty("--zoom-pos-y","50%");pop_img.style.cursor="default";isZoomed=!1}
function enableZoomMode(){isZoomMode=!0;applyZoom();updateZoomButtons()}
function disableZoomMode(){isZoomMode=!1;resetZoom();updateZoomButtons()}
function attachZoomHandlers(){pop_img=document.getElementById("imagebox_sign");if(!container||!pop_img)return;container.addEventListener("mouseenter",()=>{if(isZoomMode&&!isZoomed){applyZoom()}});container.addEventListener("mouseleave",()=>{if(isZoomMode&&isZoomed){resetZoom()}});container.addEventListener("mousemove",(e)=>{if(!isZoomMode||!isZoomed)return;const rect=container.getBoundingClientRect();const percentX=((e.clientX-rect.left)*100)/rect.width;const percentY=((e.clientY-rect.top)*100)/rect.height;container.style.setProperty("--zoom-pos-x",`${percentX}%`);container.style.setProperty("--zoom-pos-y",`${percentY}%`)});container.addEventListener("wheel",(e)=>{if(!isZoomMode||!isZoomed)return;e.preventDefault();zoomLevel+=e.deltaY*-zoomSpeed;zoomLevel=Math.min(Math.max(zoomLevel,minZoom),maxZoom);container.style.setProperty("--zoom",zoomLevel)})}
